# Server
PORT=3001
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL=postgresql://chess_user:chess_password_secure@localhost:5433/chess_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379  # Alternative: use URL format

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS - comma separated origins
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Stockfish (optional - path to stockfish binary if not in PATH)
# STOCKFISH_PATH=/usr/local/bin/stockfish

# Email (Gmail SMTP for password reset)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Frontend URL (used in password reset email links)
CLIENT_URL=http://localhost:5173